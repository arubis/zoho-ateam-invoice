# Zoho Books OAuth credentials
# Get these from https://api-console.zoho.com/ (Self Client app)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Zoho Books org ID (Settings → General in Zoho Books)
ZOHO_ORG_ID=

# Customer ID for the contractor/client being invoiced
# Find it in Zoho Books → Contacts → <Customer> → URL
ZOHO_CUSTOMER_ID=

# Bank account ID to record payments against
# Find it in Zoho Books → Banking → <Account> → URL
ZOHO_BANK_ACCOUNT_ID=

# Invoice number prefix (default: INV)
# e.g. "INV" → INV-12345, "ACME" → ACME-12345
ZOHO_INVOICE_PREFIX=INV

# Hourly rate in USD (default: 90)
ZOHO_RATE=90
